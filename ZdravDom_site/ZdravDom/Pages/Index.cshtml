@page
@model IndexModel
@{
    ViewData["Title"] = "Центр восстановления здоровья";
}

<!-- ══════════════════════════════════════════
     HERO SECTION
══════════════════════════════════════════ -->
<section class="hero" id="hero">
    <div class="hero-bg">
        <div class="hero-overlay"></div>
        <div class="hero-particles" id="heroParticles"></div>
    </div>

    <div class="container hero-content">
        <div class="hero-badge reveal-up">
            <span class="pulse-dot"></span>
            Центр восстановления здоровья · Краснодар
        </div>
        <h1 class="hero-title reveal-up delay-1">
            Убираем боль в спине за, <em>1–3 сеанса</em>
            + восстанавливаем нервную систему без таблеток с<br>
            <em> выгодой до 15%</em><br> за курс — авторский подход двух профильных специалистов
        </h1>
        
        <div class="hero-actions reveal-up delay-3">
            <button class="btn btn-cta btn-lg" onclick="openModal()">Записаться на приём</button>
            <a href="#services" class="btn btn-ghost btn-lg">Узнать больше
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </a>
        </div>
        <div class="hero-stats reveal-up delay-4">
            <div class="stat">
                <span class="stat-num" data-count="500">0</span><span>+</span>
                <span class="stat-label">пациентов</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat">
                <span class="stat-num" data-count="7">0</span><span>+</span>
                <span class="stat-label">лет опыта</span>
            </div>
            <div class="stat-divider"></div>
           
        </div>
    </div>

    <a href="#services" class="hero-scroll-hint">
        <span>Листайте вниз</span>
        <div class="scroll-line"></div>
    </a>
</section>

<!-- ══════════════════════════════════════════
     ABOUT / MISSION
══════════════════════════════════════════ -->
<section class="about-section" id="about">
    <div class="container">
        <div class="about-grid">
            <div class="about-text">
                <span class="section-tag reveal-up">О нас</span>
                <h2 class="section-title reveal-up delay-1">Место, где работают <em>в команде</em> ради вашего здоровья</h2>
                <p class="body-text reveal-up delay-2">
                    Мы занимаемся восстановлением опорно-двигательного аппарата. Наш комплексный подход и командная работа дают результаты, недостижимые для частных мастеров и обычных клиник.
                </p>
                <p class="body-text reveal-up delay-3">
                    Мы успешно работаем с межпозвоночными грыжами и протрузиями, спондилезом, коксартрозом, спондилоартрозом, сколиозом — и подавляющим большинством других проблем опорно-двигательного аппарата.
                </p>
                <div class="about-features reveal-up delay-4">
                    <div class="feature-item">
                        <div class="feature-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                                <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <div>
                            <strong>Командный подход</strong>
                            <span>Разные специалисты — единый результат</span>
                        </div>
                    </div>
                    <div class="feature-item">
                        <div class="feature-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
                                <path d="M12 6v6l4 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                            </svg>
                        </div>
                        <div>
                            <strong>Индивидуальный подбор</strong>
                            <span>Программа под вашу ситуацию</span>
                        </div>
                    </div>
                    <div class="feature-item">
                        <div class="feature-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                                <path d="M20 7H4C2.9 7 2 7.9 2 9v10c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V9c0-1.1-.9-2-2-2z" stroke="currentColor" stroke-width="1.5"/>
                                <path d="M16 3H8L6 7h12l-2-4z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <div>
                            <strong>Доказанные техники</strong>
                            <span>Методики с подтверждённой эффективностью</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="about-visual reveal-right">
                <div class="about-img-wrap">
                    <div class="about-img-placeholder">
                        <div class="placeholder-pattern"></div>
                        <span>Место практики · ЗдравДом</span>
                    </div>
                    <div class="about-img-accent"></div>
                </div>
                <div class="about-quote">
                    <blockquote>
                        «Истинная причина боли в спине, суставах и шее — в мышцах. Мы освобождаем их от спазмов.»
                    </blockquote>
                    <cite>Кирилл, хиропрактик</cite>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════
     SERVICES
══════════════════════════════════════════ -->
<section class="services-section" id="services">
    <div class="container">
        <div class="section-header reveal-up">
            <span class="section-tag">Что мы предлагаем</span>
            <h2 class="section-title">Четыре направления <em>для вашего здоровья</em></h2>
            <p class="section-sub">Каждая практика — отдельная история исцеления. Вместе — полная программа восстановления.</p>
        </div>

        <div class="services-grid">

            <div class="service-card reveal-up delay-1" data-href="/kirill">
                <div class="service-card-inner">
                    <div class="service-num">01</div>
                    <div class="service-icon">
                        <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                            <path d="M20 5 C20 5, 30 14 30 22 C30 27.5 25.5 32 20 32 C14.5 32 10 27.5 10 22 C10 14 20 5 20 5Z" stroke="currentColor" stroke-width="1.5" fill="none"/>
                            <path d="M13 19 Q20 16 27 19" stroke="currentColor" stroke-width="1.2" fill="none"/>
                            <path d="M14 23 Q20 20 26 23" stroke="currentColor" stroke-width="1" fill="none"/>
                        </svg>
                    </div>
                    <h3>Хиропрактика</h3>
                    <p>Миопрессура, акупрессура, висцеральная терапия и мануальные практики — авторский метод Кирилла для устранения боли в спине, шее и суставах.</p>
                    <div class="service-tags">
                        <span>Грыжи</span>
                        <span>Спондилез</span>
                        <span>Сколиоз</span>
                        <span>ЖКТ</span>
                    </div>
                    <a href="/kirill" class="service-link">
                        Подробнее
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                            <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </a>
                </div>
            </div>

            <div class="service-card reveal-up delay-2" data-href="/denis">
                <div class="service-card-inner">
                    <div class="service-num">02</div>
                    <div class="service-icon">
                        <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                            <circle cx="20" cy="20" r="8" stroke="currentColor" stroke-width="1.5"/>
                            <circle cx="20" cy="20" r="13" stroke="currentColor" stroke-width="1" stroke-dasharray="2 3"/>
                            <circle cx="20" cy="20" r="4" fill="currentColor" opacity="0.3"/>
                            <path d="M20 8 L20 5 M20 35 L20 32 M8 20 L5 20 M35 20 L32 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        </svg>
                    </div>
                    <h3>Саунд-хилинг</h3>
                    <p>Тибетские поющие чаши, гонги и колокола — звуковые вибрации проходят вглубь тела, снимая нервное напряжение и психосоматические мышечные блоки.</p>
                    <div class="service-tags">
                        <span>Стресс</span>
                        <span>Бессонница</span>
                        <span>Апатия</span>
                        <span>Нервная система</span>
                    </div>
                    <a href="/denis" class="service-link">
                        Подробнее
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                            <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </a>
                </div>
            </div>

            <div class="service-card reveal-up delay-3">
                <div class="service-card-inner">
                    <div class="service-num">03</div>
                    <div class="service-icon">
                        <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                            <circle cx="20" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/>
                            <path d="M20 13 L20 24 M15 17 L20 15 L25 17 M20 24 L16 32 M20 24 L24 32" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                    <h3>Телесная терапия</h3>
                    <p>Комплекс упражнений, подобранный специально для вас. Специалист научит, проконтролирует и поможет восстановить двигательную активность мышц.</p>
                    <div class="service-tags">
                        <span>Реабилитация</span>
                        <span>Упражнения</span>
                        <span>Движение</span>
                    </div>
                    <button class="service-link" onclick="openModal()">
                        Записаться
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                            <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                </div>
            </div>

            <div class="service-card reveal-up delay-4">
                <div class="service-card-inner">
                    <div class="service-num">04</div>
                    <div class="service-icon">
                        <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                            <circle cx="14" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/>
                            <circle cx="26" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/>
                            <circle cx="20" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/>
                            <path d="M8 26 C8 20 12 18 14 18 M32 26 C32 20 28 18 26 18 M14 26 C14 21 17 19 20 19 C23 19 26 21 26 26" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        </svg>
                    </div>
                    <h3>Групповые медитации</h3>
                    <p>Воскресные медитации под тибетские чаши и чайные церемонии. Социальная активность, принятие тела, тёплое общение с единомышленниками.</p>
                    <div class="service-tags">
                        <span>По воскресениям</span>
                        <span>Чайная церемония</span>
                        <span>Сообщество</span>
                    </div>
                    <button class="service-link" onclick="openModal()">
                        Записаться
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                            <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════
     SPECIALISTS — без слоганов
══════════════════════════════════════════ -->
<section class="specialists-section" id="specialists">
    <div class="container">
        <div class="section-header reveal-up">
            <span class="section-tag">Наши специалисты</span>
        </div>

        <div class="specialists-grid">

            <div class="specialist-card reveal-up delay-1">
                <div class="specialist-photo-wrap">
                    <img src="~/images/kirill.jpg" alt="Кирилл — хиропрактик" class="specialist-photo" onerror="this.parentElement.classList.add('photo-fallback')"/>
                    <div class="specialist-photo-placeholder">
                        <span>К</span>
                    </div>
                    <div class="specialist-badge">Хиропрактик</div>
                </div>
                <div class="specialist-info">
                    <h3>Кирилл</h3>
                    <p class="specialist-role">Хиропрактик · Специалист по опорно-двигательному аппарату</p>
                    <p>Многолетний опыт работы с самыми сложными случаями. Автор метода, объединяющего миопрессуру, акупрессуру и висцеральную терапию.</p>
                    <div class="specialist-skills">
                        <span>Миопрессура</span>
                        <span>Акупрессура</span>
                        <span>Висцеральная терапия</span>
                        <span>Хиропрактика</span>
                    </div>
                    <a href="/kirill" class="btn btn-outline">О специалисте</a>
                </div>
            </div>

            <div class="specialist-card reveal-up delay-2">
                <div class="specialist-photo-wrap">
                    <img src="~/images/denis.jpg" alt="Денис — саунд-хилер" class="specialist-photo" onerror="this.parentElement.classList.add('photo-fallback')"/>
                    <div class="specialist-photo-placeholder">
                        <span>Д</span>
                    </div>
                    <div class="specialist-badge">Саунд-хилер</div>
                </div>
                <div class="specialist-info">
                    <h3>Денис</h3>
                    <p class="specialist-role">Саунд-хилер · Практик звуковых медитаций</p>
                    <p>Несколько лет исследует влияние звука и вибрации на состояние человека. Объединяет знания о дыхании, энергетике и глубоком расслаблении.</p>
                    <div class="specialist-skills">
                        <span>Тибетские чаши</span>
                        <span>Гонги</span>
                        <span>Медитации</span>
                        <span>Ретриты</span>
                    </div>
                    <a href="/denis" class="btn btn-outline">О специалисте</a>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════
     TARIFFS
══════════════════════════════════════════ -->
<section class="tariffs-section" id="tariffs">
    <div class="container">
        <div class="section-header reveal-up">
            <span class="section-tag">Тарифы</span>
            <h2 class="section-title">Скидка до <em>15%</em></h2>
            <p class="section-sub">Выберите формат, который подходит именно вам</p>
        </div>

        <div class="tariffs-grid">

            <div class="tariff-card reveal-up delay-1">
                <div class="tariff-header">
                    <span class="tariff-tag">Хиропрактика</span>
                    <div class="tariff-price">
                        <span class="price-num">—</span>
                        <span class="price-unit">₽ / сеанс</span>
                    </div>
                </div>
                <ul class="tariff-features">
                    <li>Первичный приём (90–120 мин)</li>
                    <li>Диагностика и работа с триггерами</li>
                    <li>Висцеральный массаж</li>
                    <li>Мануальные практики</li>
                    <li>Рекомендации по упражнениям</li>
                </ul>
                <button class="btn btn-cta w-full" onclick="openModal()">Записаться</button>
                <span class="tariff-note"></span>
            </div>

            <div class="tariff-card tariff-featured reveal-up delay-2">
                <div class="tariff-popular">Популярное</div>
                <div class="tariff-header">
                    <span class="tariff-tag">Курс хиропрактики</span>
                    <div class="tariff-price">
                        <span class="price-num">—</span>
                        <span class="price-unit">₽ / курс</span>
                    </div>
                </div>
                <ul class="tariff-features">
                    <li>5 сеансов хиропрактики</li>
                    <li>Индивидуальный план реабилитации</li>
                    <li>Телесная терапия в программе</li>
                    <li>Комплекс домашних упражнений</li>
                    <li>Поддержка между сеансами</li>
                    <li>Скидка относительно разовых</li>
                </ul>
                <button class="btn btn-cta w-full" onclick="openModal()">Записаться</button>
                <span class="tariff-note"></span>
            </div>

            <div class="tariff-card reveal-up delay-3">
                <div class="tariff-header">
                    <span class="tariff-tag">Саунд-хилинг</span>
                    <div class="tariff-price">
                        <span class="price-num">—</span>
                        <span class="price-unit">₽ / сессия</span>
                    </div>
                </div>
                <ul class="tariff-features">
                    <li>Индивидуальные и групповые сессии(60–90 мин)</li>
                    <li>Тибетские чаши, гонги, колокола</li>
                    <li>Дыхательные практики</li>
                    <li>Настройка под ваш запрос</li>
                    <li>Рекомендации после сессии</li>
                </ul>
                <button class="btn btn-cta w-full" onclick="openModal()">Записаться</button>
                <span class="tariff-note"></span>
            </div>

        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════
     REVIEWS
══════════════════════════════════════════ -->
<section class="reviews-section" id="reviews">
    <div class="container">
        <div class="section-header reveal-up">
            <span class="section-tag">Отзывы</span>
            <h2 class="section-title">Они уже <em>вернулись к жизни</em></h2>
        </div>

        <div class="reviews-track-wrap">
            <div class="reviews-track" id="reviewsTrack">

                <div class="review-card">
                    <div class="review-stars">★★★★★</div>
                    <blockquote>Пришёл больным, ушёл здоровым! Спасибо большое Кирилл за помощь, это самая лучшая работа в мире! Продолжайте заботиться о здоровье людей, у вас это круто получается!</blockquote>
                    <div class="review-author">
                        <span class="review-name">Ратмир</span>
                        <span class="review-meta">28 лет · военный</span>
                    </div>
                </div>

                <div class="review-card">
                    <div class="review-stars">★★★★★</div>
                    <blockquote>Проходила курс массажа, обратилась с болями в поясничной области. Огромное спасибо! Прошло два месяца, выполняю рекомендации и чувствую себя намного лучше! Кирилл очень грамотный специалист и добрый отзывчивый человек.</blockquote>
                    <div class="review-author">
                        <span class="review-name">Надежда</span>
                        <span class="review-meta">52 года · домохозяйка</span>
                    </div>
                </div>

                <div class="review-card">
                    <div class="review-stars">★★★★★</div>
                    <blockquote>После первого же сеанса перестала болеть спина, плечи, голова и прекратились панические атаки, даже настроение улучшилось. Всем рекомендую.</blockquote>
                    <div class="review-author">
                        <span class="review-name">Альфия</span>
                        <span class="review-meta">44 года · бухгалтер</span>
                    </div>
                </div>

                <div class="review-card">
                    <div class="review-stars">★★★★★</div>
                    <blockquote>Обратился с болью в копчике — такой, что ни сидеть, ни ходить. Через 4 дня боль стала утихать, через неделю прошла. Кирилл очень крутой специалист, всем рекомендую!</blockquote>
                    <div class="review-author">
                        <span class="review-name">Алексей</span>
                        <span class="review-meta">40 лет · предприниматель</span>
                    </div>
                </div>

                <div class="review-card">
                    <div class="review-stars">★★★★★</div>
                    <blockquote>После первой же процедуры я, наконец, смог спокойно поспать ночью. Никогда не был так близок к тому, чтобы победить свои больные мышцы. Процедура идёт на конечный результат, без ограничений по времени.</blockquote>
                    <div class="review-author">
                        <span class="review-name">Александр</span>
                        <span class="review-meta">38 лет · программист</span>
                    </div>
                </div>

            </div>

            <div class="reviews-nav">
                <button class="reviews-btn" id="reviewsPrev" aria-label="Назад">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                        <path d="M12 4L6 10L12 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </button>
                <div class="reviews-dots" id="reviewsDots"></div>
                <button class="reviews-btn" id="reviewsNext" aria-label="Вперёд">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                        <path d="M8 4L14 10L8 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </button>
            </div>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════
     FORMATS
══════════════════════════════════════════ -->
<section class="formats-section" id="formats">
    <div class="container">
        <div class="section-header reveal-up">
            <span class="section-tag">Форматы приёма</span>
            <h2 class="section-title">Здоровье там, где удобно <em>Вам</em></h2>
        </div>
        <div class="formats-grid">
            <div class="format-card reveal-up delay-1">
