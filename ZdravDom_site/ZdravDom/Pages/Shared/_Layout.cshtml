                <a href="/#specialists" class="nav-link">Специалисты</a>
                <a href="/#tariffs" class="nav-link">Тарифы</a>
                <a href="/#reviews" class="nav-link">Отзывы</a>
                <a href="/#contact" class="nav-link">Контакты</a>
